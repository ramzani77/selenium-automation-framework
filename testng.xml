<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CrossBrowserSuite" parallel="tests" thread-count="3">

    <listeners>
        <listener class-name="com.sameer.test.listeners.TestListener"/>
        <listener class-name="com.sameer.test.listeners.RetryListener"/>
    </listeners>

    <!-- Chrome -->
    <test name="Chrome Test">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.sameer.test.tests.LoginTest"/>
        </classes>
    </test>

    <!-- Firefox -->
    <test name="Firefox Test">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.sameer.test.tests.LoginTest"/>
        </classes>
    </test>

    <!-- Edge -->
<!--    <test name="Edge Test">-->
<!--        <parameter name="browser" value="edge"/>-->
<!--        <classes>-->
<!--            <class name="com.sameer.test.tests.LoginTest"/>-->
<!--        </classes>-->
<!--    </test>-->

</suite>